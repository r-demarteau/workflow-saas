# ── Stripe ──────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs for each plan (create in Stripe Dashboard → Products)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...

# ── Public vars (exposed to browser) ────────────────────────────────────────
# The URL this frontend is deployed at (no trailing slash)
PUBLIC_BASE_URL=https://teamdock.ai

# ── Provisioning ─────────────────────────────────────────────────────────────
# URL of the provisioning API on your server that spins up tenant stacks
PROVISION_API_URL=http://127.0.0.1:3050/provision
# Shared secret between this app and the provisioning API
PROVISION_API_SECRET=changeme
