# ── Auth ─────────────────────────────────────────────────────────────────────
# Must match PROVISION_API_SECRET in workflow-saas .env
PROVISION_API_SECRET=changeme-use-a-long-random-string

# ── Server ────────────────────────────────────────────────────────────────────
PROVISIONER_PORT=3050

# ── Paths ─────────────────────────────────────────────────────────────────────
TENANTS_DIR=/opt/nemofirm/tenants
NGINX_DIR=/etc/nginx/sites-available
DOMAIN=nemofirm.com

# ── Docker image ──────────────────────────────────────────────────────────────
# The pre-built woo_client_codex image on your registry
APP_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/woo-client:latest

# ── SMTP (for welcome emails) ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=NemoFirm <noreply@nemofirm.com>
